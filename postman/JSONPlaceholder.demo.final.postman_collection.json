    {
      "name": "GET Posts List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Тест 1: статус 200 OK\r",
              "pm.test(\"Статус ответа 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Тест 2: время ответа меньше 1 секунды\r",
              "pm.test(\"Время ответа меньше 1000 мс\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(1000);\r",
              "});\r",
              "\r",
              "// Тест 3: ответ — массив постов\r",
              "pm.test(\"Ответ содержит массив постов\", function () {\r",
              "    pm.expect(pm.response.json()).to.be.an(\"array\");\r",
              "    pm.expect(pm.response.json().length).to.be.at.least(1);\r",
              "});\r",
              "\r",
              "// Тест 4: первый пост имеет title и body\r",
              "pm.test(\"Первый пост имеет title и body\", function () {\r",
              "    var firstPost = pm.response.json()[0];\r",
              "    pm.expect(firstPost.title).to.be.a(\"string\");\r",
              "    pm.expect(firstPost.body).to.be.a(\"string\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
